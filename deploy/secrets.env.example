# Copy this to deploy/secrets.env ON THE HOST and fill in real values.
# deploy/secrets.env is gitignored — it must NEVER be committed.

# Discord bot token (from the Discord Developer Portal).
DISCORD_TOKEN=

# Gemini via the OpenClaw-style config (see cloud_llm.py).
OPENCLAW_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
OPENCLAW_API_KEY=
OPENCLAW_MODEL=gemini-2.5-flash
OPENCLAW_API_STYLE=gemini

# Optional tuning (safe defaults exist in code):
# VOICE_TTS_SPEED=1.25
# VOICE_REPLY_MAX_TOKENS=200
